{
  "permissions": {
    "allow": [
      "Bash(./bring-up.sh)",
      "Bash(./bring-down.sh)",
      "Bash(curl -s -o /dev/null -w *)",
      "Bash(curl -s http://localhost:8080/actuator/health*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/checkstyle-hook.sh"
          }
        ]
      }
    ]
  }
}
